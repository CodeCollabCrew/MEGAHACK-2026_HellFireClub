PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-workspace

# GROQ AI (FREE) — get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# Google OAuth for Gmail (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:3000

# JWT
JWT_SECRET=any-random-32-char-string-change-in-production
